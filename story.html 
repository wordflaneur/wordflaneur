<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Story — WordFlaneur</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <div class="container">
        <!-- ===== HEADER ===== -->
        <header>
            <div class="logo"><a href="index.html">📜 Word<span>Flaneur</span></a></div>
            <nav>
                <a href="index.html">Home</a>
                <a href="library.html">Library</a>
                <a href="about.html">About</a>
                <a href="dashboard.html">Dashboard</a>
            </nav>
            <div id="auth-section">
                <span id="user-greeting">Guest</span>
                <button class="btn-outline" id="login-btn" onclick="handleLogin()">Sign In</button>
                <button class="btn-outline hidden" id="logout-btn" onclick="handleLogout()">Logout</button>
                <button class="btn" id="publish-btn" onclick="window.location.href='publish.html'" style="display:none;">✍️ Publish</button>
            </div>
        </header>

        <!-- ===== STORY CONTENT ===== -->
        <div id="story-container" style="margin-top: 20px;">
            <!-- Story header -->
            <div id="story-header">
                <h1 id="story-title" style="color: #3d2b1f;">The Ember Crown</h1>
                <p id="story-author" style="color: #7a6b5a; font-style: italic;">by Elara Vance</p>
                <div id="story-tags" class="story-tags">
                    <span class="story-tag">Dark Fantasy</span>
                    <span class="story-tag">Political</span>
                    <span class="story-tag">Slow Burn</span>
                </div>
                <div style="display: flex; gap: 15px; margin: 10px 0; font-size: 14px; color: #5a4d3e;">
                    <span>⭐ RIS: <span id="story-ris">247</span></span>
                    <span>🔦 Spotlights: <span id="story-spotlights">12</span></span>
                    <span>📖 Chapters: <span id="story-chapters">5</span></span>
                    <span>💬 Comments: <span id="story-comments">8</span></span>
                </div>
                <button class="btn-gold" id="spotlight-btn" onclick="handleSpotlight()">🔦 Spotlight</button>
                <hr style="margin: 20px 0; border: 1px solid #ede6db;">
            </div>

            <!-- Chapter list -->
            <div id="chapter-list">
                <h3 style="color: #3d2b1f;">📖 Chapters</h3>
                <div id="chapters-container">
                    <div class="chapter-block" style="background: #faf8f5; padding: 15px; border-radius: 12px; margin: 10px 0; border-left: 4px solid #b8860b;">
                        <h4 style="color: #6b4f3c;">Chapter 1: The Fall</h4>
                        <p style="color: #5a4d3e;">The protagonist loses her position at court...</p>
                        <a href="#" onclick="alert('Chapter 1 content would appear here.')" style="color: #b8860b;">Read Chapter</a>
                    </div>
                    <div class="chapter-block" style="background: #faf8f5; padding: 15px; border-radius: 12px; margin: 10px 0; border-left: 4px solid #b8860b;">
                        <h4 style="color: #6b4f3c;">Chapter 2: The Return</h4>
                        <p style="color: #5a4d3e;">She returns to her family estate...</p>
                        <a href="#" onclick="alert('Chapter 2 content would appear here.')" style="color: #b8860b;">Read Chapter</a>
                    </div>
                </div>
            </div>

            <!-- Comments section -->
            <div id="comments-section" style="margin-top: 30px;">
                <h3 style="color: #3d2b1f;">💬 Comments</h3>
                <div id="comments-container">
                    <div style="background: #ffffff; padding: 15px; border-radius: 12px; border: 1px solid #e8ddd0; margin: 8px 0;">
                        <p style="font-weight: bold; color: #6b4f3c;">BookWorm42</p>
                        <p style="color: #2c2c2c;">The atmosphere in this chapter is incredible. I can feel the weight of her loss.</p>
                    </div>
                    <div style="background: #ffffff; padding: 15px; border-radius: 12px; border: 1px solid #e8ddd0; margin: 8px 0;">
                        <p style="font-weight: bold; color: #6b4f3c;">FantasyFanatic</p>
                        <p style="color: #2c2c2c;">This is exactly what I've been looking for. Dark, political, and slow-burn.</p>
                    </div>
                </div>
                <textarea id="comment-input" placeholder="Leave a comment..." rows="3" style="width: 100%; padding: 12px; margin: 10px 0; background: #faf8f5; border: 1px solid #d4c5a0; border-radius: 10px;"></textarea>
                <button class="btn" onclick="alert('Comment submitted! (Demo)')">Submit Comment</button>
            </div>
        </div>

        <!-- ===== FOOTER ===== -->
        <footer style="margin-top: 40px; padding-top: 20px; border-top: 2px solid #d4c5a0; text-align: center; color: #7a6b5a; font-size: 14px;">
            <p>📜 WordFlaneur — It's OK to Be Slower.</p>
            <p><a href="about.html">About</a> · <a href="#">Privacy</a> · <a href="#">Terms</a> · <a href="#">Support</a></p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="js/config.js"></script>
    <script src="js/supabase.js"></script>
    <script src="js/auth.js"></script>
    <script src="js/database.js"></script>
    <script src="js/algorithm.js"></script>
    <script>
        function handleLogin() { window.location.href = 'login.html'; }
        async function handleLogout() { const r = await signOut(); if (r.success) window.location.reload(); else alert('Error signing out'); }
        function handleSpotlight() { alert('Spotlight given! (Demo)'); }
        async function checkAuth() {
            const r = await getCurrentUser();
            if (r.success && r.user) {
                const p = await getUserProfile(r.user.id);
                if (p.success) {
                    document.getElementById('user-greeting').textContent = `👋 ${p.profile.display_name || 'User'}`;
                    document.getElementById('login-btn').classList.add('hidden');
                    document.getElementById('logout-btn').classList.remove('hidden');
                    if (p.profile.role === 'admin' || p.profile.role === 'author') {
                        document.getElementById('publish-btn').style.display = 'inline-block';
                    }
                }
            }
        }
        checkAuth();
    </script>
</body>
</html>
